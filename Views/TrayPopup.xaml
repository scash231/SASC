<UserControl x:Class="SASC.Views.TrayPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220">
    <Border Background="#0f1117"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="8">
        <StackPanel>
            <Border Background="#0d1117" CornerRadius="8 8 0 0" Padding="12 8">
                <TextBlock Text="Quick Switch"
                           Foreground="White"
                           FontFamily="Segoe UI"
                           FontSize="12" FontWeight="SemiBold"/>
            </Border>

            <StackPanel x:Name="AccountList" Margin="6 6 6 4"/>

            <Border Height="1" Background="#1e1e1e" Margin="6 0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="6 6 6 8">
                <Button x:Name="BtnOpen" Content="Open SAS"
                        Width="90" Height="26"
                        FontFamily="Segoe UI" FontSize="11"
                        Background="#1f538d" Foreground="White"
                        BorderThickness="0" Margin="0 0 4 0"
                        Click="BtnOpen_Click"/>
                <Button x:Name="BtnExit" Content="Exit"
                        Width="60" Height="26"
                        FontFamily="Segoe UI" FontSize="11"
                        Background="#2a2a2a" Foreground="#aaa"
                        BorderThickness="0"
                        Click="BtnExit_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
