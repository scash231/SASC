<Window x:Class="SASC.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="440" Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0a0a0f"
        BorderBrush="#1a1a2e"
        BorderThickness="1">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#0f0f1a"/>
            <Setter Property="Foreground"      Value="#c0c0c0"/>
            <Setter Property="CaretBrush"      Value="#5865f2"/>
            <Setter Property="BorderBrush"     Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8 5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#1a1a2e"
                                    BorderThickness="0 0 0 1">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Padding"    Value="12 8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root" Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <TextBlock x:Name="Txt"
                                       Text="{TemplateBinding Header}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Txt" Property="Foreground" Value="#5865f2"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#5865f2"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="0 0 0 2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Txt" Property="Foreground" Value="#aaaacc"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#0f0f1a"/>
            <Setter Property="Foreground"      Value="#888"/>
            <Setter Property="BorderBrush"     Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8 0 24 0" VerticalAlignment="Center"/>
                            <TextBlock Text="▾" Foreground="#444"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0 0 8 0" FontSize="10" IsHitTestVisible="False"/>
                            <ToggleButton Focusable="False" Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="#0f0f1a" BorderBrush="#1e1e2e"
                                        BorderThickness="1" CornerRadius="5"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0f0f1a"/>
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Setter Property="Padding"    Value="8 5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#1a1a2e"/>
                                            <Setter Property="Foreground" Value="#aaaacc"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#13132a"/>
                                            <Setter Property="Foreground" Value="#5865f2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings"
                   Foreground="#aaaacc" FontFamily="Segoe UI"
                   FontSize="14" FontWeight="SemiBold" Margin="0 0 0 16"/>

        <TabControl Grid.Row="1">

            <!-- General -->
            <TabItem Header="General">
                <StackPanel Margin="0 16 0 0">
                    <TextBlock Text="When X is pressed"
                               Foreground="#333355" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 0 0 8"/>
                    <RadioButton x:Name="RbTray"
                                 Content="Hide to system tray  (keep running in background)"
                                 Margin="0 0 0 4"/>
                    <RadioButton x:Name="RbExit"
                                 Content="Exit completely  (close the application)"
                                 Margin="0 0 0 20"/>

                    <TextBlock Text="After switching account"
                               Foreground="#333355" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 0 0 8"/>
                    <CheckBox x:Name="ChkMinimize"
                              Content="Minimize SAS" Margin="0 0 0 6"/>
                    <CheckBox x:Name="ChkAutoStart"
                              Content="Start SAS with Windows" Margin="0 0 0 20"/>

                    <TextBlock Text="Kill wait (seconds)"
                               Foreground="#333355" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBox x:Name="TxtKillWait" Width="60" Height="28"
                             HorizontalAlignment="Left"/>
                    <TextBlock Text="How long to wait after a launcher closes before relaunching."
                               Foreground="#252535" FontFamily="Segoe UI"
                               FontSize="10" Margin="0 4 0 0"/>
                </StackPanel>
            </TabItem>

            <!-- Steam -->
            <TabItem Header="Steam">
                <StackPanel Margin="0 16 0 0">
                    <TextBlock Text="Steam install path"
                               Foreground="#333355" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBox x:Name="TxtSteamPath" Height="28"/>

                    <TextBlock Text="Extra launch arguments"
                               Foreground="#333355" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 16 0 6"/>
                    <TextBox x:Name="TxtLaunchArgs" Height="28"/>
                    <TextBlock Text="e.g.  -silent  -noverifyfiles"
                               Foreground="#252535" FontFamily="Segoe UI"
                               FontSize="10" Margin="0 4 0 20"/>

                    <TextBlock Text="Auto Login"
                               Foreground="#333355" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBlock Text="Switch to this account automatically when SAS starts."
                               Foreground="#444" FontFamily="Segoe UI" FontSize="11"
                               Margin="0 0 0 8" TextWrapping="Wrap"/>
                    <ComboBox x:Name="CmbAutoLogin" Height="28" Width="240"
                              HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>

            <!-- Epic Games -->
            <TabItem Header="Epic Games">
                <StackPanel Margin="0 16 0 0">
                    <TextBlock Text="Epic Games launcher path"
                               Foreground="#333355" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBox x:Name="TxtEpicPath" Height="28"/>
                    <TextBlock Text="Full path to EpicGamesLauncher.exe"
                               Foreground="#252535" FontFamily="Segoe UI"
                               FontSize="10" Margin="0 4 0 20"/>

                    <Border Background="#0d0d1a" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <TextBlock Text="⚠  Epic Games support is coming in a future update."
                                       Foreground="#333355" FontFamily="Segoe UI"
                                       FontSize="10" TextWrapping="Wrap"/>
                            <TextBlock Text="Settings saved here will be used once the feature ships."
                                       Foreground="#252535" FontFamily="Segoe UI"
                                       FontSize="10" TextWrapping="Wrap" Margin="0 4 0 0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- About -->
            <TabItem Header="About">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="scash´s" Foreground="#5865f2"
                               FontFamily="Segoe UI" FontSize="20"
                               FontWeight="Bold" HorizontalAlignment="Center"
                               Margin="0 24 0 4"/>
                    <TextBlock Text="Account Switcher"
                               Foreground="#333" FontFamily="Segoe UI" FontSize="12"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtVersion"
                               Foreground="#252535" FontFamily="Segoe UI" FontSize="10"
                               HorizontalAlignment="Center" Margin="0 6 0 0"/>
                    <TextBlock Text="Built with C# and WPF&#x0a;"
                               Foreground="#1e1e2e" FontFamily="Segoe UI" FontSize="10"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0 14 0 0"/>
                </StackPanel>
            </TabItem>

        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Content="cancel" Width="80" Height="30"
                    Background="#0f0f1a" Foreground="#444"
                    FontFamily="Segoe UI" FontSize="11"
                    Margin="0 0 6 0" Click="BtnCancel_Click"/>
            <Button Content="save" Width="80" Height="30"
                    Background="#5865f2" Foreground="White"
                    FontFamily="Segoe UI" FontSize="11"
                    Margin="0 0 6 0" Click="BtnSave_Click"/>
            <Button Content="save &amp; exit" Width="96" Height="30"
                    Background="#3a3f6e" Foreground="#aaaacc"
                    FontFamily="Segoe UI" FontSize="11"
                    Click="BtnSaveExit_Click"/>
        </StackPanel>
    </Grid>
</Window>
