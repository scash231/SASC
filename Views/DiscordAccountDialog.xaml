<Window x:Class="SASC.Views.DiscordAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discord Account"
        Height="511" Width="380"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Background="#0a0a0f"
        BorderBrush="#1a1a2e"
        BorderThickness="1">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0"
                      GlassFrameThickness="0,0,0,0" CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="#0f0f1a"/>
            <Setter Property="Foreground"               Value="#c0c0c0"/>
            <Setter Property="CaretBrush"               Value="#5865f2"/>
            <Setter Property="BorderBrush"              Value="#1e1e2e"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="Padding"                  Value="8 0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" MinHeight="34">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="8 0"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="6"/>
            <Setter Property="MinWidth"        Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Focusable="False" Height="0.001"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBg" Background="#252535"
                                                        CornerRadius="3" Margin="1 2 1 2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Background" Value="#5865f2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Background" Value="#4a57d4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Focusable="False" Height="0.001"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.18"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#07070f"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="14 0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#5865f2" Margin="0 0 8 0"/>
                    <TextBlock Text="discord account"
                               Foreground="#aaaacc" FontFamily="Segoe UI" FontSize="12"/>
                </StackPanel>
                <Button Content="✕" Width="28" Height="22" FontSize="10"
                        Background="Transparent" Foreground="#333355"
                        HorizontalAlignment="Right" Click="BtnCancel_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20 16 20 20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0 0 0 10">
                <TextBlock Text="DISPLAY NAME" Foreground="#333355" FontFamily="Segoe UI"
                           FontSize="9" FontWeight="Bold" Margin="0 0 0 5"/>
                <TextBox x:Name="TxtUsername" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0 0 0 10">
                <TextBlock Text="TOKEN" Foreground="#333355" FontFamily="Segoe UI"
                           FontSize="9" FontWeight="Bold" Margin="0 0 0 5"/>
                <TextBox x:Name="TxtToken" Height="34"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0 0 0 10">
                <TextBlock Text="NOTE  (optional)" Foreground="#333355" FontFamily="Segoe UI"
                           FontSize="9" FontWeight="Bold" Margin="0 0 0 5"/>
                <TextBox x:Name="TxtNote" Height="34"/>
            </StackPanel>

            <Border Grid.Row="3" Background="#0c0c1a" CornerRadius="5"
                    Padding="10 8" Margin="0 4 0 0">
                <StackPanel>
                    <TextBlock Text="HOW TO GET YOUR TOKEN"
                               Foreground="#2a2a55" FontFamily="Segoe UI"
                               FontSize="9" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBlock Text="1. Open discord.com/app in your browser"
                               Foreground="#333355" FontFamily="Segoe UI" FontSize="10" Margin="0 0 0 2"/>
                    <TextBlock Text="2. Press F12 → Console tab"
                               Foreground="#333355" FontFamily="Segoe UI" FontSize="10" Margin="0 0 0 2"/>
                    <TextBlock Text="3. Enable mobile view: Ctrl + Shift + M"
                               Foreground="#333355" FontFamily="Segoe UI" FontSize="10" Margin="0 0 0 6"/>
                    <TextBlock Text="4. Paste this and press Enter:"
                               Foreground="#333355" FontFamily="Segoe UI" FontSize="10" Margin="0 0 0 4"/>
                    <Border Background="#08081a" CornerRadius="4" Padding="8 6" Margin="0 0 0 6">
                        <TextBox IsReadOnly="True"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#5865f2" FontFamily="Consolas"
                                 FontSize="9" TextWrapping="Wrap" IsTabStop="False"
                                 Text="const iframe = document.createElement('iframe'); console.log(JSON.parse(document.body.appendChild(iframe).contentWindow.localStorage.token)); iframe.remove();"/>
                    </Border>
                    <TextBlock Text="5. Copy the token that appears in the console"
                               Foreground="#333355" FontFamily="Segoe UI" FontSize="10"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="5" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="cancel" Width="90" Height="30"
                        Background="#0f0f1a" Foreground="#444"
                        FontSize="11" Margin="0 0 8 0" Click="BtnCancel_Click"/>
                <Button Content="save" Width="90" Height="30"
                        Background="#5865f2" Foreground="White"
                        FontSize="11" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
