<Window x:Class="SASC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Account Switcher"
        Height="580" Width="480"
        MinHeight="300" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#0a0a0f"
        BorderBrush="#1a1a2e"
        BorderThickness="1">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0,0,0,0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#0f0f1a"/>
            <Setter Property="Foreground"      Value="#888"/>
            <Setter Property="BorderBrush"     Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8 0 24 0" VerticalAlignment="Center"/>
                            <TextBlock Text="▾" Foreground="#444"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0 0 8 0" FontSize="10" IsHitTestVisible="False"/>
                            <ToggleButton Focusable="False" Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="#0f0f1a" BorderBrush="#1e1e2e"
                                        BorderThickness="1" CornerRadius="5"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0f0f1a"/>
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Setter Property="Padding"    Value="8 5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#1a1a2e"/>
                                            <Setter Property="Foreground" Value="#aaaacc"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#13132a"/>
                                            <Setter Property="Foreground" Value="#5865f2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="6"/>
            <Setter Property="MinWidth"        Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0" Focusable="False" Height="0.001"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBg" Background="#252535"
                                                        CornerRadius="3" Margin="1 2 1 2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Background" Value="#5865f2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Background" Value="#4a57d4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0" Focusable="False" Height="0.001"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition x:Name="ManualHeaderRow" Height="24"/>
            <RowDefinition x:Name="ManualListRow"   Height="0"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border Grid.Row="0" Background="#07070f"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="14 0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#5865f2" Margin="0 0 8 0"/>
                    <TextBlock Text="scash´s Account Switcher" Foreground="#5865f2"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnImport" Content="import"
                            Width="46" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#3a3a5a"
                            Margin="0 0 4 0" Click="BtnImport_Click"/>
                    <Button x:Name="BtnExport" Content="export"
                            Width="46" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#3a3a5a"
                            Margin="0 0 4 0" Click="BtnExport_Click"/>
                    <Button x:Name="BtnSettings" Content="settings"
                            Width="56" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#4a4a6a"
                            Margin="0 0 8 0" Click="BtnSettings_Click"/>
                    <Button Content="—" Width="28" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#333355"
                            Margin="0 0 2 0" Click="BtnMinimize_Click"/>
                    <Button Content="✕" Width="28" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#333355"
                            Click="BtnCloseWindow_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Platform Toggle -->
        <Border Grid.Row="1" Background="#07070f"
                BorderBrush="#0f0f1a" BorderThickness="0 0 0 1">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Bottom" Margin="12 0 0 0">
                <Border x:Name="TabSteamBorder"
                        BorderBrush="#5865f2" BorderThickness="0 0 0 2" Margin="0 0 2 0">
                    <Button x:Name="BtnTabSteam" Content="Steam"
                            Width="80" Height="28" FontFamily="Segoe UI" FontSize="11"
                            Background="Transparent" Foreground="#5865f2"
                            BorderThickness="0" Click="BtnTabSteam_Click"/>
                </Border>
                <Border x:Name="TabEpicBorder"
                        BorderBrush="Transparent" BorderThickness="0 0 0 2" Margin="0 0 2 0">
                    <Button x:Name="BtnTabEpic" Content="Epic Games"
                            Width="90" Height="28" FontFamily="Segoe UI" FontSize="11"
                            Background="Transparent" Foreground="#333"
                            BorderThickness="0" Click="BtnTabEpic_Click"/>
                </Border>
                <Border x:Name="TabDiscordBorder"
                        BorderBrush="Transparent" BorderThickness="0 0 0 2" Margin="0 0 2 0">
                    <Button x:Name="BtnTabDiscord" Content="Discord"
                            Width="80" Height="28" FontFamily="Segoe UI" FontSize="11"
                            Background="Transparent" Foreground="#333"
                            BorderThickness="0" Click="BtnTabDiscord_Click"/>
                </Border>
                <Border BorderBrush="Transparent" BorderThickness="0 0 0 2">
                    <Button Content="more launchers coming soon"
                            Width="180" Height="28" FontFamily="Segoe UI" FontSize="13"
                            Background="Transparent" Foreground="#1e1e2e"
                            BorderThickness="0" IsEnabled="False" Cursor="Arrow"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Section label -->
        <TextBlock x:Name="TxtSectionLabel" Grid.Row="2"
                   Text="STEAM" Foreground="#252535" FontFamily="Segoe UI"
                   FontSize="9" FontWeight="Bold"
                   Margin="14 0 0 0" VerticalAlignment="Center"/>

        <!-- Steam list -->
        <ScrollViewer x:Name="SteamScrollViewer"
                      Grid.Row="3" Margin="10 2 10 4"
                      VerticalScrollBarVisibility="Auto">
            <ScrollViewer.RenderTransform>
                <TranslateTransform x:Name="SteamTranslate" X="0"/>
            </ScrollViewer.RenderTransform>
            <StackPanel x:Name="SteamList"/>
        </ScrollViewer>

        <!-- Epic list -->
        <ScrollViewer x:Name="EpicScrollViewer"
                      Grid.Row="3" Margin="10 2 10 4"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <ScrollViewer.RenderTransform>
                <TranslateTransform x:Name="EpicTranslate" X="0"/>
            </ScrollViewer.RenderTransform>
            <StackPanel x:Name="EpicList"/>
        </ScrollViewer>

        <!-- Discord list -->
        <ScrollViewer x:Name="DiscordScrollViewer"
                      Grid.Row="3" Margin="10 2 10 4"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <ScrollViewer.RenderTransform>
                <TranslateTransform x:Name="DiscordTranslate" X="0"/>
            </ScrollViewer.RenderTransform>
            <StackPanel x:Name="DiscordList"/>
        </ScrollViewer>

        <!-- Divider -->
        <Border Grid.Row="4" Background="#0d0d18" Margin="10 0"/>

        <!-- Manual header -->
        <Grid Grid.Row="5" Margin="14 0 12 0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="MANUAL" Foreground="#252535" FontFamily="Segoe UI"
                           FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtManualCount" Foreground="#333355"
                           FontFamily="Segoe UI" FontSize="9"
                           VerticalAlignment="Center" Margin="6 0 0 0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="BtnToggleManual" Content="▸"
                        Width="18" Height="18" FontSize="9"
                        Background="Transparent" Foreground="#333355"
                        Margin="0 0 6 0" Click="BtnToggleManual_Click"/>
                <Button x:Name="BtnAddAccount" Content="+ add"
                        Width="38" Height="18" FontSize="9"
                        Background="Transparent" Foreground="#5865f2"
                        Click="BtnAddAccount_Click"/>
            </StackPanel>
        </Grid>

        <!-- Manual list -->
        <ScrollViewer Grid.Row="6" Margin="10 0 10 4"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ManualList"/>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="7" Background="#07070f">
            <Grid Margin="14 0">
                <TextBlock x:Name="TxtStatus" Text="ready"
                           Foreground="#252535" FontFamily="Segoe UI"
                           FontSize="9" VerticalAlignment="Center"/>
                <Button Content="↻" Width="22" Height="18" FontSize="10"
                        Background="Transparent" Foreground="#2a2a3a"
                        HorizontalAlignment="Right" Click="BtnRefresh_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
