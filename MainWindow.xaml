<Window x:Class="SASC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SASC"
        Height="580" Width="480"
        MinHeight="420" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a0f"
        BorderBrush="#1a1a2e"
        BorderThickness="1">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#0f0f1a"/>
            <Setter Property="Foreground"      Value="#c0c0c0"/>
            <Setter Property="CaretBrush"      Value="#5865f2"/>
            <Setter Property="BorderBrush"     Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="6 4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#0f0f1a"/>
            <Setter Property="Foreground"      Value="#888"/>
            <Setter Property="BorderBrush"     Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5"/>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="8 0 24 0" VerticalAlignment="Center"/>
                            <TextBlock Text="▾" Foreground="#444"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0 0 8 0" FontSize="10" IsHitTestVisible="False"/>
                            <ToggleButton Focusable="False" Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False">
                                <Border Background="#0f0f1a" BorderBrush="#1e1e2e"
                                        BorderThickness="1" CornerRadius="5"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0f0f1a"/>
                        <Setter Property="Foreground" Value="#888"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize"   Value="11"/>
                        <Setter Property="Padding"    Value="8 5"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#1a1a2e"/>
                                            <Setter Property="Foreground" Value="#aaaacc"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#13132a"/>
                                            <Setter Property="Foreground" Value="#5865f2"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="38"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition x:Name="ManualHeaderRow" Height="24"/>
            <RowDefinition x:Name="ManualListRow"   Height="0"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border Grid.Row="0" Background="#07070f">
            <Grid Margin="14 0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="scash´s" Foreground="#5865f2"
                               FontFamily="Segoe UI" FontSize="14"
                               FontWeight="Bold" Margin="0 0 8 0"/>
                    <TextBlock Text="Account Switcher"
                               Foreground="#333" FontFamily="Segoe UI"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnImport" Content="import"
                            Width="46" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#3a3a5a"
                            Margin="0 0 4 0" Click="BtnImport_Click"/>
                    <Button x:Name="BtnExport" Content="export"
                            Width="46" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#3a3a5a"
                            Margin="0 0 4 0" Click="BtnExport_Click"/>
                    <Button x:Name="BtnSettings" Content="settings"
                            Width="56" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#4a4a6a"
                            Click="BtnSettings_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Platform Toggle -->
<Border Grid.Row="1" Background="#07070f"
        BorderBrush="#0f0f1a" BorderThickness="0 0 0 1">
    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Bottom" Margin="12 0 0 0">

        <Border x:Name="TabSteamBorder"
                BorderBrush="#5865f2" BorderThickness="0 0 0 2" Margin="0 0 2 0">
            <Button x:Name="BtnTabSteam" Content="Steam"
                    Width="80" Height="28"
                    FontFamily="Segoe UI" FontSize="11"
                    Background="Transparent" Foreground="#5865f2"
                    BorderThickness="0" Click="BtnTabSteam_Click"/>
        </Border>

        <Border x:Name="TabEpicBorder"
                BorderBrush="Transparent" BorderThickness="0 0 0 2" Margin="0 0 2 0">
            <Button x:Name="BtnTabEpic" Content="Epic Games"
                    Width="90" Height="28"
                    FontFamily="Segoe UI" FontSize="11"
                    Background="Transparent" Foreground="#333"
                    BorderThickness="0" Click="BtnTabEpic_Click"/>
        </Border>

        <!-- Coming Soon tab -->
        <Border BorderBrush="Transparent" BorderThickness="0 0 0 2">
            <Button Content="more launchers coming soon"
                    Width="180" Height="28"
                    FontFamily="Segoe UI" FontSize="13"
                    Background="Transparent" Foreground="#1e1e2e"
                    BorderThickness="0" IsEnabled="False"
                    Cursor="Arrow"/>
        </Border>

    </StackPanel>
</Border>

        <!-- Search + Sort -->
        <Grid Grid.Row="2" Margin="12 6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtSearch" Grid.Column="0"
                     Height="26" Margin="0 0 6 0"
                     TextChanged="TxtSearch_TextChanged"/>
            <ComboBox x:Name="CmbSort" Grid.Column="1" Height="26"
                      SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="name"     Tag="name" IsSelected="True"/>
                <ComboBoxItem Content="username" Tag="username"/>
                <ComboBoxItem Content="recent"   Tag="recent"/>
            </ComboBox>
        </Grid>

        <!-- Section label -->
        <TextBlock x:Name="TxtSectionLabel" Grid.Row="3"
                   Text="STEAM"
                   Foreground="#252535" FontFamily="Segoe UI"
                   FontSize="9" FontWeight="Bold"
                   Margin="14 0 0 0" VerticalAlignment="Center"/>

<!-- Steam list -->
<ScrollViewer x:Name="SteamScrollViewer"
              Grid.Row="4" Margin="10 2 10 4"
              VerticalScrollBarVisibility="Auto">
    <ScrollViewer.RenderTransform>
        <TranslateTransform x:Name="SteamTranslate" X="0"/>
    </ScrollViewer.RenderTransform>
    <StackPanel x:Name="SteamList"/>
</ScrollViewer>

<!-- Epic list -->
<ScrollViewer x:Name="EpicScrollViewer"
              Grid.Row="4" Margin="10 2 10 4"
              VerticalScrollBarVisibility="Auto"
              Visibility="Collapsed">
    <ScrollViewer.RenderTransform>
        <TranslateTransform x:Name="EpicTranslate" X="0"/>
    </ScrollViewer.RenderTransform>
    <StackPanel x:Name="EpicList"/>
</ScrollViewer>


        <!-- Divider -->
        <Border Grid.Row="5" Background="#0d0d18" Margin="10 0"/>

        <!-- Manual header -->
        <Grid Grid.Row="6" Margin="14 0 12 0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="MANUAL"
                           Foreground="#252535" FontFamily="Segoe UI"
                           FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtManualCount"
                           Foreground="#333355" FontFamily="Segoe UI"
                           FontSize="9" VerticalAlignment="Center" Margin="6 0 0 0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="BtnToggleManual" Content="▸"
                        Width="18" Height="18" FontSize="9"
                        Background="Transparent" Foreground="#333355"
                        Margin="0 0 6 0" Click="BtnToggleManual_Click"/>
                <Button x:Name="BtnAddAccount" Content="+ add"
                        Width="38" Height="18" FontSize="9"
                        Background="Transparent" Foreground="#5865f2"
                        Click="BtnAddAccount_Click"/>
            </StackPanel>
        </Grid>

        <!-- Manual list -->
        <ScrollViewer Grid.Row="7" Margin="10 0 10 4"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ManualList"/>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="8" Background="#07070f">
            <Grid Margin="14 0">
                <TextBlock x:Name="TxtStatus" Text="ready"
                           Foreground="#252535" FontFamily="Segoe UI"
                           FontSize="9" VerticalAlignment="Center"/>
                <Button Content="↻" Width="22" Height="18" FontSize="10"
                        Background="Transparent" Foreground="#2a2a3a"
                        HorizontalAlignment="Right" Click="BtnRefresh_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
