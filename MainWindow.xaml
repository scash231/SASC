<Window x:Class="SASC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SAS"
        Height="560" Width="480"
        MinHeight="400" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#0a0a0f"
        BorderBrush="#1a1a2e"
        BorderThickness="1">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#0f0f1a"/>
            <Setter Property="Foreground"      Value="#c0c0c0"/>
            <Setter Property="CaretBrush"      Value="#5865f2"/>
            <Setter Property="BorderBrush"     Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="8 5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#0f0f1a"/>
            <Setter Property="Foreground"  Value="#888"/>
            <Setter Property="BorderBrush" Value="#1e1e2e"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="11"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>        <!-- Titlebar -->
            <RowDefinition Height="44"/>        <!-- Search -->
            <RowDefinition Height="18"/>        <!-- Steam label -->
            <RowDefinition Height="*"/>         <!-- Steam list -->
            <RowDefinition Height="1"/>         <!-- Divider -->
            <RowDefinition x:Name="ManualHeaderRow" Height="24"/>   <!-- Manual label -->
            <RowDefinition x:Name="ManualListRow"   Height="0"/>    <!-- Manual list (collapsed by default) -->
            <RowDefinition Height="32"/>        <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border Grid.Row="0" Background="#07070f">
            <Grid Margin="14 0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="SAS" Foreground="#5865f2"
                               FontFamily="Segoe UI" FontSize="14"
                               FontWeight="Bold" Margin="0 0 8 0"/>
                    <TextBlock Text="Steam Account Switcher"
                               Foreground="#333" FontFamily="Segoe UI"
                               FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="BtnImport" Content="import"
                            Width="46" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#3a3a5a"
                            Margin="0 0 4 0" Click="BtnImport_Click"/>
                    <Button x:Name="BtnExport" Content="export"
                            Width="46" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#3a3a5a"
                            Margin="0 0 4 0" Click="BtnExport_Click"/>
                    <Button x:Name="BtnSettings" Content="settings"
                            Width="56" Height="22" FontSize="10"
                            Background="Transparent" Foreground="#4a4a6a"
                            Click="BtnSettings_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="1" Margin="12 8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtSearch" Grid.Column="0"
                     Height="28" Margin="0 0 6 0"
                     TextChanged="TxtSearch_TextChanged"/>
            <ComboBox x:Name="CmbSort" Grid.Column="1" Height="28"
                      SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="name"     Tag="name" IsSelected="True"/>
                <ComboBoxItem Content="username" Tag="username"/>
                <ComboBoxItem Content="recent"   Tag="recent"/>
            </ComboBox>
        </Grid>

        <!-- Steam label -->
        <TextBlock Grid.Row="2" Text="STEAM"
                   Foreground="#252535" FontFamily="Segoe UI"
                   FontSize="9" FontWeight="Bold"
                   Margin="14 0 0 0" VerticalAlignment="Center"/>

        <!-- Steam list -->
        <ScrollViewer Grid.Row="3" Margin="10 2 10 4"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SteamList"/>
        </ScrollViewer>

        <!-- Divider -->
        <Border Grid.Row="4" Background="#0d0d18" Margin="10 0"/>

        <!-- Manual label + toggle -->
        <Grid Grid.Row="5" Margin="14 0 12 0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="MANUAL"
                           Foreground="#252535" FontFamily="Segoe UI"
                           FontSize="9" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtManualCount"
                           Foreground="#333355" FontFamily="Segoe UI"
                           FontSize="9" VerticalAlignment="Center"
                           Margin="6 0 0 0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="BtnToggleManual" Content="▸"
                        Width="18" Height="18" FontSize="9"
                        Background="Transparent" Foreground="#333355"
                        Margin="0 0 6 0"
                        Click="BtnToggleManual_Click"/>
                <Button x:Name="BtnAddAccount" Content="+ add"
                        Width="38" Height="18" FontSize="9"
                        Background="Transparent" Foreground="#5865f2"
                        Click="BtnAddAccount_Click"/>
            </StackPanel>
        </Grid>

        <!-- Manual list (height controlled in code) -->
        <ScrollViewer Grid.Row="6" Margin="10 0 10 4"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ManualList"/>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="7" Background="#07070f">
            <Grid Margin="14 0">
                <TextBlock x:Name="TxtStatus" Text="ready"
                           Foreground="#252535" FontFamily="Segoe UI"
                           FontSize="9" VerticalAlignment="Center"/>
                <Button Content="↻" Width="22" Height="18" FontSize="10"
                        Background="Transparent" Foreground="#2a2a3a"
                        HorizontalAlignment="Right"
                        Click="BtnRefresh_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
